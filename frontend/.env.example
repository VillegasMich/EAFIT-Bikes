# Base URL for the backend API (geolocalization microservice or future API gateway)
VITE_API_BASE_URL=http://localhost:8080

# Base URL for the Bikes microservice (will move behind API gateway later)
# Leave empty to use the Vite dev proxy (recommended for local development).
# The proxy forwards /bikes/* to http://localhost:8000 (configured in vite.config.ts).
# VITE_BIKES_API_BASE_URL=

# Base URL for the Reservations microservice
# Leave empty to use the Vite dev proxy (recommended for local development).
# The proxy forwards /reservations/* to http://localhost:8001 (configured in vite.config.ts).
# Set this only when deploying without the Vite proxy (e.g. production builds).
# VITE_RESERVATIONS_API_URL=

# Base URL for the Eventos (events) microservice
# Defaults to http://localhost:3000 if not set.
# VITE_EVENTS_API_URL=http://localhost:3000

# Base URL for the Auth service (Firebase ID token sync: health, login, register)
# Example: http://localhost:3000 or http://10.0.1.229:3000
# VITE_AUTH_CLIENT_API_URL=

# Firebase Web App config (Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
